# .dockerignore
# Docker 빌드 컨텍스트에서 제외할 파일 목록
# 이 파일들은 Docker 이미지에 포함되지 않습니다.

# Git 관련 파일
.git
.gitignore

# Go 빌드 캐시 및 바이너리
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# 테스트 결과
*.test
*.out
coverage.html
coverage.out

# 개발 도구 설정
.vscode/
.idea/
*.swp
*.swo
*~

# 문서 (이미지에 불필요)
*.md
docs/

# 환경 설정 (보안상 이미지에 포함하면 안 됨!)
.env
.env.*
*.pem
*.key
*.crt

# 로컬 설정
docker-compose*.yml
Makefile
